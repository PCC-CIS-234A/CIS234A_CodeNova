<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title || 'PCC Food Pantry' %></title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <div class="navbar">
    <a href="/" class="navbar-brand">
      <img src="/pcc-logo.png" alt="PCC Logo" class="navbar-logo" />
      <span class="navbar-title">PCC Food Pantry</span>
    </a>

    <div>
      <% if (currentUser) { %>
        <% /* ----- Noah's code: role-based nav links ----- */ %>
        <% const _navRole = String(currentUser.role || '').trim().toLowerCase(); %>
        <% if (_navRole === 'manager') { %>
          <a href="/sendNotification">Send Notification</a>&nbsp;&nbsp;
          <a href="/notifications/log">Notification Log</a>&nbsp;&nbsp;&nbsp;
        <% } else if (_navRole === 'staff') { %>
          <a href="/notifications/log">Notification Log</a>&nbsp;&nbsp;&nbsp;
        <% } %>
        <% /* ----- end Noah's code ----- */ %>
        <span>Hello, <%= currentUser.first_name %>!&nbsp;&nbsp;&nbsp;</span>
        <form method="POST" action="/logout" class="inline-form">
          <button type="submit" class="btn-link">Logout</button>
        </form>
      <% } else { %>
        <% /* ----- Saul's code ----- */ %>
        <% if (typeof devBypassActive !== 'undefined' && devBypassActive) { %>
          <a href="/sendNotification">Send Notification</a>&nbsp;&nbsp;
          <a href="/notifications/log">Notification Log</a>&nbsp;&nbsp;&nbsp;
        <% } else { %>
          <a href="/login">Login</a>
          <a href="/signup">Create Account</a>
          <% if (typeof devBypassAvailable !== 'undefined' && devBypassAvailable) { %>
          <a href="/dev-bypass">Dev Bypass</a>
          <% } %>
        <% } %>
        <% /* ----- end Saul's code ----- */ %>
      <% } %>
    </div>
  </div>

  <div class="page">
